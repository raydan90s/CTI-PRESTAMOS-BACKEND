PORT=3000

# Auth (JWT propio) — genera el secret con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-aleatorio
JWT_EXPIRES_IN=7d

# Supabase — acceso por API HTTPS (443), porque la VPN de ESPOL bloquea el 5432.
SUPABASE_URL=https://TU-PROJECT-ID.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Conexión directa Postgres (opcional; solo funciona fuera de la VPN)
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST:5432/postgres

# InvenTree (servidor ESPOL, solo accesible por VPN)
INVENTREE_URL=https://inventree.cti.espol.edu.ec
INVENTREE_TOKEN=inv-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INVENTREE_STATUS_PRESTADO=91
INVENTREE_STATUS_DISPONIBLE=10
